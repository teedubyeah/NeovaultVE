# Copy this file to .env and fill in your values before starting the app.
#
# Generate the two required secrets by running this command TWICE
# and pasting each output into the corresponding variable below:
#
#   openssl rand -hex 64
#
# The app will REFUSE TO START if these are missing or left blank.

# ── Server port ───────────────────────────────────────────────────────────────
APP_PORT=8080

# ── REQUIRED secrets (generate with: openssl rand -hex 64) ───────────────────
JWT_SECRET=
ENCRYPTION_PEPPER=

# ── Public URL (used in share invite links) ───────────────────────────────────
# For local use:  http://YOUR_SERVER_IP:8080
# With a domain:  https://notes.yourdomain.com
APP_URL=http://localhost:8080

# ── Email / SMTP (optional — for share invite emails) ────────────────────────
# Leave blank to use console fallback (invite links printed to backend logs).
# Configure via Admin → Email / SMTP in the web UI after first login instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NeovisionVE <no-reply@yourdomain.com>
