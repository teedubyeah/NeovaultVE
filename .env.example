# Copy this to .env and fill in your values
# Generate secrets with: openssl rand -hex 64

# Port the app will be available on (default: 8080)
APP_PORT=8080

# REQUIRED: Change these before running in production!
JWT_SECRET=change-this-to-a-long-random-secret-in-production
ENCRYPTION_PEPPER=change-this-pepper-in-production

# ── Email / SMTP (for sharing features) ──────────────────────────────────────
# Leave blank to use console fallback (dev mode — emails printed to terminal)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NeovisionVE <no-reply@yourdomain.com>

# Public URL of your app (used in share invite links)
APP_URL=http://localhost:8080
